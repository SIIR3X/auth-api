APP_ENV=production
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
APP_PUBLIC_URL=https://api.example.com
TRUSTED_PROXY_CIDRS=172.18.0.0/16,10.0.0.0/8

DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=2
DB_ACQUIRE_TIMEOUT_SECS=30
REDIS_POOL_SIZE=10

JWT_ACCESS_EXPIRY_SECS=900
JWT_REFRESH_EXPIRY_SECS=2592000
JWT_MAX_SESSION_LIFETIME_SECS=7776000
JWT_STRICT_SESSION_BINDING=false

ARGON2_MEMORY_KIB=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=4
TOTP_ISSUER=ExampleApp
TOTP_SKEW=1
RECOVERY_CODE_EXPIRY_DAYS=365

RATE_LIMIT_RPM=300
RATE_LIMIT_AUTH_RPM=20
RATE_LIMIT_FAIL_OPEN=false
RATE_LIMIT_ALLOW_MISSING_IP=false
LOCKOUT_THRESHOLD=10
LOCKOUT_DURATION_SECS=1800
SENSITIVE_ACTION_REAUTH_SECS=600

GEOIP_DB_PATH=/app/data/GeoLite2-City.mmdb
GEOIP_REQUIRED=true
RISK_ALERT_THRESHOLD=30
RISK_CHALLENGE_THRESHOLD=60
RISK_BLOCK_THRESHOLD=80
RISK_HISTORY_DAYS=90

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM_NAME=Example API
SMTP_FROM_ADDRESS=no-reply@example.com
MAIL_TEMPLATES_DIR=/app/templates
MAIL_DEFAULT_LOCALE=en

CAPTCHA_VERIFY_URL=https://hcaptcha.com/siteverify
CAPTCHA_TIMEOUT_SECS=5
CAPTCHA_FAIL_OPEN=false

CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOW_CREDENTIALS=true

AUDIT_LOG_RETENTION_MONTHS=6
LOG_LEVEL=info
LOG_FORMAT=json

WEBAUTHN_RP_ID=api.example.com
WEBAUTHN_RP_ORIGIN=https://api.example.com
WEBAUTHN_RP_NAME=Example API
