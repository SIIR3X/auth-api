LOKI_IMAGE=grafana/loki:3.6.0
LOKI_BIND_IP=127.0.0.1
LOKI_PORT=3100
LOKI_DATA_DIR=/srv/rust-api-data/observability/loki
LOKI_CONFIG_FILE=/srv/rust-api-data/observability/config/loki-config.yml

GRAFANA_IMAGE=grafana/grafana:11.6
GRAFANA_BIND_IP=127.0.0.1
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ROOT_URL=http://127.0.0.1:3001
GRAFANA_ALLOW_SIGN_UP=false
GRAFANA_DATA_DIR=/srv/rust-api-data/observability/grafana
GRAFANA_PROVISIONING_DIR=/srv/rust-api-data/observability/config/grafana/provisioning

ALLOY_IMAGE=grafana/alloy:v1.12.0
ALLOY_BIND_IP=127.0.0.1
ALLOY_PORT=12345
ALLOY_DATA_DIR=/srv/rust-api-data/observability/alloy
ALLOY_CONFIG_FILE=/srv/rust-api-data/observability/config/alloy.config.alloy
