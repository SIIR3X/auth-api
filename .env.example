# Application
APP_ENV=development # development | production | test

# Logging
LOG_LEVEL=info # trace | debug | info | warn | error, or rust_api=debug,tower_http=info
LOG_FORMAT=pretty # pretty | json

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgres://user:password@localhost:5432/rust_api
DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=2
DB_ACQUIRE_TIMEOUT_SECS=30

# Redis
REDIS_URL=redis://localhost:6379
REDIS_POOL_SIZE=10

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ACCESS_EXPIRY_SECS=900 # 15 min
JWT_REFRESH_EXPIRY_SECS=2592000 # 30 days

# Crypto / Argon2id
ARGON2_MEMORY_KIB=65536 # 64 MB
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=4

# TOTP
TOTP_ISSUER=MyApp
# 32-byte AES-256-GCM key encoded in base64 (openssl rand -base64 32)
ENCRYPTION_KEY=change-me-to-base64-encoded-32-byte-key

# Rate limiting
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=50

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=change-me
SMTP_FROM_NAME=MyApp
SMTP_FROM_ADDRESS=no-reply@example.com

# Mail templates
MAIL_TEMPLATES_DIR=templates
MAIL_DEFAULT_LOCALE=en
