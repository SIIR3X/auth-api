# Environment: development | production | test
APP_ENV=development

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
APP_PUBLIC_URL=http://localhost:3000
# Comma-separated list of reverse-proxy CIDRs trusted to supply X-Forwarded-For / X-Real-IP.
# Leave empty when the API is exposed directly.
TRUSTED_PROXY_CIDRS=

# Database (PostgreSQL)
DATABASE_URL=postgres://user:password@localhost:5432/rust_api
DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=2
DB_ACQUIRE_TIMEOUT_SECS=30

# Redis
REDIS_URL=redis://localhost:6379
REDIS_POOL_SIZE=10
# Max wait time (ms) to acquire a connection from the Redis pool. Prevents queue buildup under load.
REDIS_WAIT_TIMEOUT_MS=2000

# JWT
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ACCESS_EXPIRY_SECS=900
JWT_REFRESH_EXPIRY_SECS=2592000
# Set to true to bind refresh tokens to the IP recorded at login (breaks mobile roaming)
JWT_STRICT_SESSION_BINDING=false

# Argon2id password hashing (tune for your hardware)
ARGON2_MEMORY_KIB=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=4

# TOTP / 2FA
TOTP_ISSUER=MyApp
TOTP_SKEW=1
RECOVERY_CODE_EXPIRY_DAYS=365
# 32-byte AES-256-GCM key, base64-encoded: openssl rand -base64 32
ENCRYPTION_KEY=change-me-to-base64-encoded-32-byte-key
# Set only during key rotation; remove after running --rotate-totp-keys
# PREVIOUS_ENCRYPTION_KEY=

# Rate limiting
RATE_LIMIT_RPM=300
RATE_LIMIT_AUTH_RPM=20
# Allow requests through if Redis is unavailable. Set to true ONLY for local dev.
# In production: false (rate limiting becomes a hard dependency).
RATE_LIMIT_FAIL_OPEN=false
# Allow requests through if the client IP cannot be determined. Set to true ONLY for local dev.
RATE_LIMIT_ALLOW_MISSING_IP=false

# Account lockout
LOCKOUT_THRESHOLD=10
LOCKOUT_DURATION_SECS=1800
# Recent re-authentication window required for destructive/sensitive actions
SENSITIVE_ACTION_REAUTH_SECS=600

# Risk scoring
# Path to the MaxMind GeoLite2-City.mmdb file; leave empty to disable geolocation signals
GEOIP_DB_PATH=
# Require the GeoIP database to be available at startup.
GEOIP_REQUIRED=false
RISK_ALERT_THRESHOLD=30
RISK_CHALLENGE_THRESHOLD=60
RISK_BLOCK_THRESHOLD=80
RISK_HISTORY_DAYS=90

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=change-me
SMTP_FROM_NAME=MyApp
SMTP_FROM_ADDRESS=no-reply@example.com

# Mail
MAIL_TEMPLATES_DIR=templates
MAIL_DEFAULT_LOCALE=en

# CAPTCHA
# CAPTCHA_SECRET=
CAPTCHA_VERIFY_URL=https://hcaptcha.com/siteverify
CAPTCHA_TIMEOUT_SECS=5
# Allow requests through when the CAPTCHA provider is unavailable. Set to true ONLY for local dev.
# In production: false (CAPTCHA becomes a hard dependency when CAPTCHA_SECRET is set).
CAPTCHA_FAIL_OPEN=false

# CORS (comma-separated origins; use * to allow all, not recommended in production)
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# Audit log retention (months; 0 = keep forever)
AUDIT_LOG_RETENTION_MONTHS=12

# Logging
LOG_LEVEL=info
LOG_FORMAT=pretty

# Tests
TEST_DATABASE_URL=postgres://rust_api_test:test_password@localhost/rust_api_test
TEST_REDIS_URL=redis://127.0.0.1:6379
