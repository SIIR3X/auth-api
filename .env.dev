APP_ENV=development

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
APP_PUBLIC_URL=http://localhost:3000
TRUSTED_PROXY_CIDRS=

# Database (matches docker-compose.dev.yml)
DATABASE_URL=postgres://auth_api:auth_api@postgres:5432/auth_api
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=1
DB_ACQUIRE_TIMEOUT_SECS=30

# Redis (matches docker-compose.dev.yml)
REDIS_URL=redis://redis:6379
REDIS_POOL_SIZE=5
REDIS_WAIT_TIMEOUT_MS=2000

# NATS
NATS_URL=nats://nats:4222

# JWT (ES256 asymmetric keys)
JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIGHAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBG0wawIBAQQg2R2G2WSdQAzqkVz/\n03JHEWNczskciWsiIKpONSbyHs2hRANCAAQwSMgY7XnreVJU6kPOBbpj1ojbSUdJ\n6O6gYhngnFmV1GVmdZ+3yplYn0JSqV8pbzzPewezpYRsBY3GXR+qf5Ji\n-----END PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMFkwEwYHKoZIzj0CAQYIKoZIzj0DAQcDQgAEMEjIGO1563lSVOpDzgW6Y9aI20lH\nSejuoGIZ4JxZldRlZnWft8qZWJ9CUqlfKW88z3sHs6WEbAWNxl0fqn+SYg==\n-----END PUBLIC KEY-----
JWT_ACCESS_EXPIRY_SECS=900
JWT_REFRESH_EXPIRY_SECS=2592000
JWT_STRICT_SESSION_BINDING=false
# Audience values stamped into the `aud` claim of access tokens (CSV).
# Each entry must match the `expected_aud` (or APP_PUBLIC_URL fallback) of a
# downstream resource server that will accept tokens minted here.
# Local stack ports: billing-api on :3001, core-api on :3002.
JWT_AUDIENCE=http://localhost:3001,http://localhost:3002

# Argon2id (lighter settings for dev)
ARGON2_MEMORY_KIB=19456
ARGON2_ITERATIONS=2
ARGON2_PARALLELISM=1
# Max concurrent Argon2 operations (defaults to CPU core count when unset)
# ARGON2_MAX_CONCURRENCY=4

# TOTP / 2FA
TOTP_ISSUER=MyApp
TOTP_SKEW=1
RECOVERY_CODE_EXPIRY_DAYS=365
ENCRYPTION_KEY=AAECAwQFBgcICQoLDA0ODxAREhMUFRYXGBkaGxwdHh8=

# Rate limiting (relaxed for dev)
RATE_LIMIT_RPM=10000
RATE_LIMIT_AUTH_RPM=1000
RATE_LIMIT_FAIL_OPEN=true
RATE_LIMIT_ALLOW_MISSING_IP=true

# Account lockout
LOCKOUT_THRESHOLD=100
LOCKOUT_DURATION_SECS=60
SENSITIVE_ACTION_REAUTH_SECS=600

# GeoIP (disabled in dev)
GEOIP_DB_PATH=
GEOIP_REQUIRED=false
RISK_ALERT_THRESHOLD=30
RISK_CHALLENGE_THRESHOLD=60
RISK_BLOCK_THRESHOLD=80
RISK_HISTORY_DAYS=90

# SMTP (Mailpit - matches docker-compose.dev.yml)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=MyApp Dev
SMTP_FROM_ADDRESS=no-reply@localhost

# Mail
MAIL_TEMPLATES_DIR=templates
MAIL_DEFAULT_LOCALE=en

# CAPTCHA (disabled in dev)
CAPTCHA_VERIFY_URL=https://hcaptcha.com/siteverify
CAPTCHA_TIMEOUT_SECS=5
CAPTCHA_FAIL_OPEN=true

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# Audit log
AUDIT_LOG_RETENTION_MONTHS=0

# Device authorization (RFC 8628)
DEVICE_AUTH_VERIFICATION_URI=http://localhost:5173/device

# Metrics (Prometheus exposition, internal listener)
METRICS_ENABLED=true
METRICS_PORT=9464

# Logging
LOG_LEVEL=debug
LOG_FORMAT=pretty
