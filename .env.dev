APP_ENV=development

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3000
APP_PUBLIC_URL=http://localhost:3000
TRUSTED_PROXY_CIDRS=

# Database (matches docker-compose.dev.yml)
DATABASE_URL=postgres://auth_api:auth_api@postgres:5432/auth_api
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=1
DB_ACQUIRE_TIMEOUT_SECS=30

# Redis (matches docker-compose.dev.yml)
REDIS_URL=redis://redis:6379
REDIS_POOL_SIZE=5
REDIS_WAIT_TIMEOUT_MS=2000

# JWT
JWT_SECRET=dev-secret-do-not-use-in-production-aabbccddeeff00112233445566778899
JWT_ACCESS_EXPIRY_SECS=900
JWT_REFRESH_EXPIRY_SECS=2592000
JWT_STRICT_SESSION_BINDING=false

# Argon2id (lighter settings for dev)
ARGON2_MEMORY_KIB=19456
ARGON2_ITERATIONS=2
ARGON2_PARALLELISM=1

# TOTP / 2FA
TOTP_ISSUER=MyApp
TOTP_SKEW=1
RECOVERY_CODE_EXPIRY_DAYS=365
ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Rate limiting (relaxed for dev)
RATE_LIMIT_RPM=10000
RATE_LIMIT_AUTH_RPM=1000
RATE_LIMIT_FAIL_OPEN=true
RATE_LIMIT_ALLOW_MISSING_IP=true

# Account lockout
LOCKOUT_THRESHOLD=100
LOCKOUT_DURATION_SECS=60
SENSITIVE_ACTION_REAUTH_SECS=600

# GeoIP (disabled in dev)
GEOIP_DB_PATH=
GEOIP_REQUIRED=false
RISK_ALERT_THRESHOLD=30
RISK_CHALLENGE_THRESHOLD=60
RISK_BLOCK_THRESHOLD=80
RISK_HISTORY_DAYS=90

# SMTP (Mailpit — matches docker-compose.dev.yml)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=MyApp Dev
SMTP_FROM_ADDRESS=no-reply@localhost

# Mail
MAIL_TEMPLATES_DIR=templates
MAIL_DEFAULT_LOCALE=en

# CAPTCHA (disabled in dev)
CAPTCHA_VERIFY_URL=https://hcaptcha.com/siteverify
CAPTCHA_TIMEOUT_SECS=5
CAPTCHA_FAIL_OPEN=true

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# Audit log
AUDIT_LOG_RETENTION_MONTHS=0

# Logging
LOG_LEVEL=debug
LOG_FORMAT=pretty
